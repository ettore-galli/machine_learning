    "version": "0.2.0",
    "configurations": [
        {
            "name": "Attach to debugpy",
            "type": "debugpy",
            "request": "attach",
            "connect": {
                "host": "localhost",
                "port": 5678
            },
            // "preLaunchTask": "python-debugpy-start"
        },
        {
            "name": "CURRENT",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}" // <-- Usa la cartella del file corrente
        },
        {
            "name": "CURRENT_PYTHONPATH",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "env": {
                "PYTHONPATH": "${fileDirname}"
            }
        },
        {
            "name": "RUN AG.1",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/agent_1/run.py",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "env": {
                "PYTHONPATH": "${fileDirname}"
            }
        },
        {
            "name": "RUN AG.2",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/agent_2/run.py",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "env": {
                "PYTHONPATH": "${fileDirname}"
            }
        },
         {
            "name": "HF demo_nli WRONG",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/agent_1/demo_nli.py",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "env": {
                "PYTHONPATH": "${fileDirname}"
            }
        },
        {
            "name": "HF RUN TRAINING 1",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/agent_1/run_training.py",
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",
            "env": {
                "PYTHONPATH": "${fileDirname}"
            }
        },
        {
            "name": "FASTAI WORK CURRENT",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
